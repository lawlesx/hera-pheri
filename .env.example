# ─────────────────────────────────────────
#  Lawless — Kite Connect credentials
#  Get from: https://kite.trade/ → Your App
# ─────────────────────────────────────────
LAWLESS_KITE_API_KEY=your_lawless_api_key
LAWLESS_KITE_API_SECRET=your_lawless_api_secret

# ─────────────────────────────────────────
#  Splinter — Kite Connect credentials
# ─────────────────────────────────────────
SPLINTER_KITE_API_KEY=your_splinter_api_key
SPLINTER_KITE_API_SECRET=your_splinter_api_secret

# ─────────────────────────────────────────
#  Turso Database (hosted SQLite)
#  Get from: https://turso.tech/
#  Run: turso db create hera-pheri
#       turso db show hera-pheri --url
#       turso db tokens create hera-pheri
# ─────────────────────────────────────────
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# ─────────────────────────────────────────
#  ⚠️  OAuth Redirect Note
#  In your Kite app settings, set redirect URL to:
#  http://127.0.0.1:3000
# ─────────────────────────────────────────
